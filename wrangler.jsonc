{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "open-helpdesk",
  "main": "apps/dashboard/.open-next/worker.js",
  "compatibility_date": "2026-03-31",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "apps/dashboard/.open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "SITE_URL": "",
    "HELP_CENTER_HOST": ""
  }
}
